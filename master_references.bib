@article{eulerichImpactAuditTechnology2023,
  title = {The {{Impact}} of {{Audit Technology}} on {{Audit Task Outcomes}}: {{Evidence}} for {{Technology}}-{{Based Audit Techniques}}*},
  shorttitle = {The {{Impact}} of {{Audit Technology}} on {{Audit Task Outcomes}}},
  author = {Eulerich, Marc and Masli, Adi and Pickerd, Jeffrey and Wood, David A.},
  year = 2023,
