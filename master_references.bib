@article{bakshiPreventReportManaging2022,
  title = {Prevent or {{Report}}? {{Managing Near Misses}} for {{Safer Operations}}},
  shorttitle = {Prevent or {{Report}}?},
  author = {Bakshi, Nitin and Peura, Heikki},
  year = 2022,
